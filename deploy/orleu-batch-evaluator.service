[Unit]
Description=Orleu Batch Evaluator (Gunicorn + Django)
After=network.target

[Service]
Type=simple
User=ai
Group=ai
WorkingDirectory=/opt/orleu-batch-evaluator
EnvironmentFile=/opt/orleu-batch-evaluator/.env
ExecStart=/opt/orleu-batch-evaluator/venv/bin/gunicorn config.wsgi:application \
    --bind 0.0.0.0:8502 \
    --workers 3 \
    --timeout 120
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
