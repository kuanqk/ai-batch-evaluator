# Django
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://orleu:orleu_secret_change_me@localhost:5432/orleu_batch_evaluator

# Redis / Celery
REDIS_URL=redis://localhost:6379/1

# NITEC LLM
NITEC_API_KEY=your-nitec-api-key-here
NITEC_BASE_URL=https://llm.nitec.kz/v1
NITEC_MODEL=openai/gpt-oss-120b
NITEC_VISION_MODEL=Qwen/Qwen3-VL-235B-A22B-Instruct
NITEC_MAX_TOKENS=4096

# Extraction / Vision OCR
MIN_TEXT_CHARS=50
VISION_MAX_PAGES=10
VISION_DPI=150

# Concurrency
NITEC_MAX_WORKERS=5
MAX_CONCURRENT_DOWNLOADS=20
MAX_CONCURRENT_VISION=3

# API auth (leave empty to disable key check)
EVALUATOR_API_KEY=

# Paths
TMP_DIR=/tmp/orleu
REPORTS_DIR=reports
RUBRICS_DIR=rubrics

# Logging
LOG_LEVEL=INFO
